{
    "name": "seeker-btcfi",
    "version": "0.1.0",
    "main": "index.ts",
    "private": true,
    "scripts": {
        "start": "expo start --dev-client",
        "start:go": "expo start",
        "android": "expo run:android",
        "prebuild": "expo prebuild",
        "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
        "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
        "format": "prettier --write \"**/*.{json,md,yml,yaml}\" && eslint . --ext .ts,.tsx,.js,.jsx --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "typecheck": "tsc --noEmit",
        "ios": "expo run:ios",
        "prepare": "simple-git-hooks",
        "bundle:analyze": "react-native-bundle-visualizer --platform android",
        "optimize:assets": "python3 scripts/optimize_assets.py"
    },
    "simple-git-hooks": {
        "pre-commit": "npx lint-staged && npx tsc --noEmit"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx}": [
            "eslint --fix"
        ],
        "*.{json,md,yml,yaml}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "@expo/vector-icons": "^15.0.3",
        "@react-native-async-storage/async-storage": "2.2.0",
        "@solana-mobile/mobile-wallet-adapter-protocol": "^2.2.8",
        "@solana-mobile/mobile-wallet-adapter-protocol-web3js": "^2.2.8",
        "@solana/spl-token": "^0.4.14",
        "@solana/web3.js": "^1.98.4",
        "@tanstack/react-query": "^5.100.10",
        "buffer": "^6.0.3",
        "expo": "~54.0.33",
        "expo-build-properties": "~1.0.10",
        "expo-clipboard": "~8.0.8",
        "expo-dev-client": "~6.0.21",
        "expo-haptics": "~15.0.8",
        "expo-notifications": "~0.32.17",
        "expo-splash-screen": "~31.0.13",
        "expo-status-bar": "~3.0.9",
        "i18next": "^26.1.0",
        "react": "19.1.0",
        "react-i18next": "^17.0.7",
        "react-native": "0.81.5",
        "react-native-bundle-visualizer": "^4.0.0",
        "react-native-get-random-values": "~1.11.0"
    },
    "devDependencies": {
        "@stylistic/eslint-plugin": "^2.13.0",
        "@testing-library/react-native": "^12.9.0",
        "@types/jest": "^29.5.14",
        "@types/react": "~19.1.0",
        "@types/react-test-renderer": "~19.1.0",
        "@typescript-eslint/eslint-plugin": "^7.18.0",
        "@typescript-eslint/parser": "^7.18.0",
        "eas-cli": "^18.12.2",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^4.6.2",
        "eslint-plugin-react-native": "^4.1.0",
        "jest": "^29.7.0",
        "jest-expo": "~54.0.0",
        "lint-staged": "^17.0.4",
        "prettier": "^3.4.2",
        "react-test-renderer": "19.1.0",
        "simple-git-hooks": "^2.13.1",
        "typescript": "~5.9.2"
    }
}
