# Solana RPC endpoint (EXPO_PUBLIC_ 접두사는 클라이언트 번들에 노출됨에 유의)
# 기본값: public mainnet RPC. 개발 중 rate limit 발생 시 Helius/QuickNode 권장.
EXPO_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Jupiter Swap API base
# lite-api.jup.ag: 무료 (rate limited)
# api.jup.ag: 인증 필요 (production)
EXPO_PUBLIC_JUPITER_API_BASE=https://lite-api.jup.ag

# Solana cluster name (mainnet-beta | devnet | testnet)
EXPO_PUBLIC_SOLANA_CLUSTER=mainnet-beta
